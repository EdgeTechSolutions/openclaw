    {
      "id": "c115a6e8-94b9-49f8-ba4b-f6de8ad10305",
      "agentId": "keynes",
      "name": "Weekly Trading Portfolio Report",
      "enabled": true,
      "createdAtMs": 1770578336587,
      "updatedAtMs": 1772265229562,
      "schedule": {
